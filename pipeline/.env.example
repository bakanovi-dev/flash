OPENAI_API_KEY=sk-...        # required for embeddings (text-embedding-3-large)
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/
DB_NAME=flashcards

# ── LLM provider for extraction + enrichment ──────────────────────────────
# Option A: OpenAI (default, no extra vars needed)
EXTRACTION_MODEL=gpt-4o-mini
ENRICHMENT_MODEL=gpt-4o

# Option B: DeepSeek (~10x cheaper, same quality)
# LLM_API_KEY=sk-...              # your DeepSeek key from platform.deepseek.com
# LLM_BASE_URL=https://api.deepseek.com
# EXTRACTION_MODEL=deepseek-chat
# ENRICHMENT_MODEL=deepseek-chat

# ── Embeddings (always OpenAI) ────────────────────────────────────────────
EMBEDDING_MODEL=text-embedding-3-large
